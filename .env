# Videoanalyse EMB – Konfiguration
# Dieses File wird automatisch beim Start geladen.
# Zeilen mit # werden ignoriert.

# ── Ollama ────────────────────────────────────────────
OLLAMA_URL=http://127.0.0.1:11434

# ── Emby ──────────────────────────────────────────────
# Emby Server URL (z.B. http://192.168.1.100:8096)
EMBY_URL=

# Emby API Key (Einstellungen → API-Schlüssel)
EMBY_API_KEY=

# ── Standardverhalten ─────────────────────────────────
# Auf "true" setzen um Flags automatisch zu aktivieren

# Vision-Analyse per Ollama automatisch aktivieren
USE_VISION=true

# NFO-Datei automatisch schreiben
WRITE_NFO=true

# Emby-Bibliothek nach Analyse automatisch aktualisieren
# (nur sinnvoll wenn EMBY_URL + EMBY_API_KEY gesetzt)
UPDATE_EMBY=false

# ── Modelle ───────────────────────────────────────────
# Standard-Whisper-Modell: tiny, base, small, medium, large
# WHISPER_MODEL=base

# ── MoviemetaDb ───────────────────────────────────────
# URL des MoviemetaDb API-Servers (z.B. http://localhost:8001)
MOVIEMETADB_URL=http://127.0.0.1:8001

# API Key (falls konfiguriert in MoviemetaDb)
MOVIEMETADB_API_KEY=

# Analyseergebnisse automatisch an MoviemetaDb senden
USE_MOVIEMETADB=true

# Standard-Vision-Modell
# VISION_MODEL=minicpm-v
